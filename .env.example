# Root .env — consumed by docker-compose.yml (variable substitution).
# Copy to .env and fill in real values. NEVER commit the real .env.

# Anthropic API key passed through to the backend + poller containers.
# BYOK note: in the deployed app users supply their own key via the UI Settings
# panel, so a server-side key is optional. It is only needed if you want the
# docker-compose backend/poller to have a default key available.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
